{
  "name": "ramadan-football-league",
  "version": "1.0.0",
  "description": "تطبيق إدارة دوري رمضان لكرة القدم",
  "main": "server.js",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "build": "npm run build:css",
    "build:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/styles.css --minify",
    "dev:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/styles.css --watch",
    "db:generate": "npx prisma generate --schema prisma/schema.prisma",
    "db:migrate": "node scripts/ensure-sqlite-db.js && npx prisma migrate dev --schema prisma/schema.prisma",
    "db:seed": "node prisma/seed.js",
    "db:ensure-admin": "node scripts/ensure-admin-user.js",
    "db:reset": "npx prisma migrate reset --force --schema prisma/schema.prisma",
    "test:setup": "node scripts/test-setup.js",
    "test": "npm run test:setup && node --test tests/app.test.js",
    "postinstall": "prisma generate --schema prisma/schema.prisma",
    "vercel-build": "node scripts/vercel-build.js"
  },
  "keywords": [
    "football",
    "ramadan",
    "express",
    "prisma",
    "sqlite"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "alpinejs": "^3.15.8",
    "bcrypt": "^6.0.0",
    "cookie-session": "^2.1.1",
    "dayjs": "^1.11.19",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1",
    "prisma": "^6.16.2",
    "sqlite3": "^5.1.7",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17"
  }
}

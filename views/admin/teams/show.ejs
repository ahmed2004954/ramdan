<section class="space-y-6">
  <div class="section-heading">
    <div>
      <p class="section-kicker">إدارة الفريق</p>
      <h1 class="section-title"><%= team.name %></h1>
    </div>
    <div class="flex flex-wrap gap-3">
      <a href="/admin/teams/<%= team.id %>/edit" class="secondary-button">تعديل بيانات الفريق</a>
      <a href="/admin/teams" class="secondary-button">العودة إلى الفرق</a>
    </div>
  </div>

  <div class="grid gap-6 xl:grid-cols-[340px_minmax(0,1fr)]">
    <aside class="glass-card p-6">
      <img src="<%= team.logoPath %>" alt="<%= team.name %>" class="h-24 w-24 rounded-[1.75rem] object-cover shadow-lg shadow-emerald-900/15" />
      <h2 class="mt-5 text-2xl font-black text-slate-900"><%= team.name %></h2>
      <p class="mt-2 text-sm text-slate-500">عدد اللاعبين الحالي: <span class="font-black text-[var(--color-accent)]"><%= team._count.players %></span></p>

      <form action="/admin/teams/<%= team.id %>/players" method="POST" class="mt-6 space-y-4">
        <label class="form-group">
          <span>إضافة لاعب جديد</span>
          <input type="text" name="name" class="form-input" placeholder="اسم اللاعب" required />
        </label>
        <button type="submit" class="primary-button w-full justify-center">إضافة اللاعب</button>
      </form>
    </aside>

    <div class="glass-card p-6">
      <div class="section-heading mb-5">
        <div>
          <p class="section-kicker">قائمة الفريق</p>
          <h2 class="text-2xl font-black">اللاعبون</h2>
        </div>
      </div>

      <% if (team.players.length) { %>
        <div class="grid gap-4 md:grid-cols-2">
          <% team.players.forEach((player, index) => { %>
            <div class="rounded-[1.75rem] border border-slate-200/70 bg-white/80 p-4 shadow-[0_16px_40px_rgba(15,81,50,0.06)]">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="text-xs font-bold text-slate-500">اللاعب <%= index + 1 %></p>
                  <h3 class="mt-2 text-lg font-black text-slate-900"><%= player.name %></h3>
                </div>
                <form action="/admin/teams/<%= team.id %>/players/<%= player.id %>/delete" method="POST">
                  <button
                    type="submit"
                    class="danger-button px-4 py-2"
                    onclick="return confirm('هل تريد حذف هذا اللاعب من الفريق؟')"
                  >
                    حذف
                  </button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <h2 class="text-2xl font-black">لا يوجد لاعبون في هذا الفريق</h2>
          <p class="mt-3 text-sm text-slate-500">أضف أول لاعب من النموذج الجانبي وسيظهر هنا مباشرة.</p>
        </div>
      <% } %>
    </div>
  </div>
</section>

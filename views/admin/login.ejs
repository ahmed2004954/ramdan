<section class="mx-auto max-w-md py-10">
  <div class="glass-card p-8">
    <p class="section-kicker">وصول الإدارة</p>
    <h1 class="section-title">تسجيل الدخول</h1>
    <p class="mt-3 text-sm leading-7 text-slate-500">استخدم حساب المدير للوصول إلى لوحة إدارة دوري رمضان.</p>

    <form action="/admin/login" method="POST" class="mt-8 space-y-5">
      <label class="form-group">
        <span>اسم المستخدم</span>
        <input type="text" name="username" class="form-input" placeholder="admin" required />
      </label>
      <label class="form-group">
        <span>كلمة المرور</span>
        <input type="password" name="password" class="form-input" placeholder="••••••••" required />
      </label>
      <button type="submit" class="primary-button w-full justify-center">دخول لوحة الإدارة</button>
    </form>
  </div>
</section>
